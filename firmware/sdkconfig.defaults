# MiniHSM — configuracion por defecto
# Copiar a sdkconfig.local y completar (sdkconfig.local esta en .gitignore)
# O usar: idf.py menuconfig

# WiFi — dejar vacio para modo provisioning
CONFIG_WIFI_SSID=""
CONFIG_WIFI_PASS=""

# ServerHSM
CONFIG_SERVERHSM_URL="https://fileserver.locker/serverHSM/api"
CONFIG_HEARTBEAT_INTERVAL_SEC=300

# ESP32-S3 — Flash 16MB (PSRAM desactivada: no es necesaria y causaba panic en arranque)
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y

# mbedTLS X.509 write — necesario para cert_manager (cert autofirmado + CSR)
CONFIG_MBEDTLS_X509_CRT_WRITE_C=y
CONFIG_MBEDTLS_X509_CSR_WRITE_C=y
CONFIG_MBEDTLS_PK_WRITE_C=y
CONFIG_MBEDTLS_ENTROPY_C=y
CONFIG_MBEDTLS_HAVE_TIME=y
CONFIG_MBEDTLS_USE_PSA_CRYPTO=y

# Bundle de certificados raiz (para que el heartbeat valide HTTPS de fileserver.locker)
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_FULL=y
